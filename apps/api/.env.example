# ─── Server ───────────────────────────────────────────────
PORT=4000
NODE_ENV=development
# Secret used to sign JWTs. Use a long random string in production.
JWT_SECRET=change-this-to-a-long-random-string
# Comma-separated list of allowed frontend origins (CORS).
CLIENT_URL=http://localhost:5173

# ─── Database (Supabase Postgres) ─────────────────────────
# Pooled connection (used by the app at runtime). Port 6543 + pgbouncer.
DATABASE_URL="postgresql://USER:PASSWORD@HOST:6543/postgres?pgbouncer=true"
# Direct connection (used by Prisma migrations). Port 5432.
DIRECT_URL="postgresql://USER:PASSWORD@HOST:5432/postgres"

# ─── AI provider (optional) ───────────────────────────────
# Google Gemini free-tier key: https://aistudio.google.com/apikey
# If omitted, AI Search falls back to a keyword RAG-lite answer.
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash
